APP_ENV=demo
DATABASE_URL=postgresql+psycopg://esg_agent:esg_agent@localhost:5432/esg_agent_demo
BACKEND_CORS_ORIGINS='["http://localhost:3000"]'
UPLOAD_DIR=backend/data/runtime/demo/uploads
DERIVED_DIR=backend/data/runtime/demo/derived
OCR_ENABLED=false
OCR_LANG=chi_sim+eng
OCR_MAX_PAGES=5
TESSERACT_CMD=
OCRMYPDF_CMD=ocrmypdf
OPENAI_COMPATIBLE_API_BASE=https://api.deepseek.com
OPENAI_COMPATIBLE_API_KEY=
LLM_MODEL=deepseek-v4-flash
LLM_THINKING_TYPE=enabled
LLM_REASONING_EFFORT=high
LLM_RESPONSE_FORMAT=json_object
LLM_MAX_TOKENS=4096
LLM_TIMEOUT_SECONDS=120
LLM_MAX_RETRIES=2
LLM_RETRY_DELAY_SECONDS=2
LLM_MAX_CONCURRENCY=8
LLM_MAX_CALLS_PER_RUN=200
LLM_PROMPT_VERSION=deepseek-gri-assist-v1
